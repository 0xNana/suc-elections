    "seed-candidates": "tsx scripts/seed-candidates.ts",
    "seed-positions": "tsx scripts/seed-positions.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.5.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
